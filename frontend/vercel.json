{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/rec/:path*", "destination": "http://144.24.67.225/rec/:path*" },
    { "source": "/chat/:path*", "destination": "http://144.24.67.225/chat/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(rec|chat)/:path*",
      "headers": [
        { "key": "x-vercel-enable-rewrite-caching", "value": "0" }
      ]
    }
  ]
}
