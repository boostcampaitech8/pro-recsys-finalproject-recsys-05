{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "step handoff summary",
  "description": "codex exec 각 step의 최종 메시지 형식. 다음 step 프롬프트에 재주입되는 이관 단위(B1).",
  "type": "object",
  "additionalProperties": false,
  "required": ["step_done", "changed_files", "decisions", "open_risks", "next_notes"],
  "properties": {
    "step_done": {
      "type": "boolean",
      "description": "이번 step 목표를 코드 변경으로 달성했는가(자기보고; 실제 게이트는 하네스 verify)."
    },
    "changed_files": {
      "type": "array",
      "items": {"type": "string"},
      "description": "수정/생성/삭제한 파일 경로(리포 기준 상대경로)."
    },
    "decisions": {
      "type": "array",
      "items": {"type": "string"},
      "description": "내린 판단·트레이드오프(다음 step이 알아야 할 것)."
    },
    "open_risks": {
      "type": "array",
      "items": {"type": "string"},
      "description": "미해결 위험·후속 확인 필요 사항."
    },
    "next_notes": {
      "type": "string",
      "description": "다음 step 실행자에게 남기는 한두 문장 인수인계."
    }
  }
}
