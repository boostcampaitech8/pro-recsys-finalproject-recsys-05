{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "codex cross-review findings",
  "description": "codex exec review 최종 메시지 형식. 클로드가 자기 diff 판정과 대조해 병기하되, findings는 즉시 수정하지 않고 사용자 판정 후 반영한다(SPEC §4.7).",
  "type": "object",
  "additionalProperties": false,
  "required": ["findings", "verdict"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "request_changes", "comment"],
      "description": "전체 판정."
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "severity", "summary"],
        "properties": {
          "file": {"type": "string"},
          "line": {"type": "integer"},
          "severity": {"type": "string", "enum": ["P1", "P2", "P3"]},
          "summary": {"type": "string"},
          "suggestion": {"type": "string"}
        }
      }
    }
  }
}
