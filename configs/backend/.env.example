# 백엔드 env (backend/.env로 복사)
#
# 실행 환경 (local, dev, prod)
ENV=local
# Docker Compose (컨테이너 간 통신):
DATABASE_URL=postgresql+asyncpg://myuser:mypassword@db:5432/mydatabase
# 로컬 예시:
# DATABASE_URL=postgresql+asyncpg://myuser:mypassword@localhost:5432/mydatabase

# Redis
# - [Hybrid 모드]: 호스트 터미널(Prefect) -> Docker(Redis) 연동 시: localhost:6380
# - [Local 단독]: 호스트 설치 Redis 사용 시: localhost:6379
# - [Docker 내부]: 서비스 간 통신 시: redis:6379/0
REDIS_URL=redis://redis:6379/0

# ML 추천 모델 루트 디렉터리
ML_REC_ROOT=/app/ml_rec

# 4. 외부 API
STEAM_API_KEY=your_steam_api_key_here

# 5. GCS (둘 중 하나 선택)
# 옵션 A: Base64 인코딩된 서비스 계정 JSON (CI/CD)
GCS_KEY_BASE64=
# 옵션 B: 서비스 계정 JSON 파일 경로 (로컬)
# 파일 경로만 적습니다 (JSON 내용 X)
# 로컬 예시: GOOGLE_APPLICATION_CREDENTIALS=./configs/gcs/gcs_key.json
# Docker 예시: GOOGLE_APPLICATION_CREDENTIALS=/app/configs/gcs/gcs_key.json
GOOGLE_APPLICATION_CREDENTIALS=./configs/gcs/gcs_key.json

# 6. Naver CLOVA Studio Settings
CLOVA_API_KEY=your_clova_api_key_here

# CLOVA API 상세 경로 (변경 필요 시 오버라이드)
# RAG 추론용
CLOVA_RAG_REASONING_URL=https://clovastudio.stream.ntruss.com/v1/api-tools/rag-reasoning
# 일반 대화용
CLOVA_CHAT_BASE_URL=https://clovastudio.stream.ntruss.com/v1/openai
# Reranker용
CLOVA_RERANKER_URL=https://clovastudio.stream.ntruss.com/v1/api-tools/reranker
