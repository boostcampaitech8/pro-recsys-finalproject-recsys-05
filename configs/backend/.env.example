# Backend environment example
# Copy this file to configs/backend/.env and fill required secrets.

# Runtime mode
ENV=prod
DEBUG_MODE=False

# Docker Compose service-to-service URLs
DATABASE_URL=postgresql+asyncpg://myuser:mypassword@db:5432/mydatabase
REDIS_URL=redis://redis:6379/0
ML_REC_ROOT=/app/ml_rec
BENTOML_SERVICE_URL=http://bentoml:3000

# External APIs
STEAM_API_KEY=
CLOVA_API_KEY=
CLOVA_BASE_URL=https://clovastudio.stream.ntruss.com/v1/openai/
CLOVA_RERANKER_URL=https://clovastudio.stream.ntruss.com/v1/api-tools/reranker

# GCS auth strategy: choose one and keep it consistent.
# A) File-based key (recommended when gcs_key.json is mounted)
GOOGLE_APPLICATION_CREDENTIALS=/app/configs/gcs/gcs_key.json
# B) Base64 key (enable only when using secret injection)
# GCS_KEY_BASE64=
