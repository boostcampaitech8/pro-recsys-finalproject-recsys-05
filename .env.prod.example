# =============================================================================
# 운영 환경 예시 (서버 관리 단일 진실원)
# 서버에서 .env.prod로 복사한 뒤 예시 값을 실제 값으로 교체하세요.
# =============================================================================

# --- 필수 키 ---
DATABASE_URL=postgresql+asyncpg://myuser:mypassword@db:5432/mydatabase
REDIS_URL=redis://redis:6379/0

DOCKER_USERNAME=your-dockerhub-namespace
IMAGE_TAG=v2026.03.04

STEAM_API_KEY=replace-with-real-steam-key
CLOVA_API_KEY=replace-with-real-clova-key
CLOVA_BASE_URL=https://clovastudio.stream.ntruss.com/v1/openai/
CLOVA_RERANKER_URL=https://clovastudio.stream.ntruss.com/v1/api-tools/reranker

# --- 선택 키 ---
ENV=prod
DEBUG_MODE=False
BENTOML_SERVICE_URL=http://bentoml:3000
ML_REC_ROOT=/app/ml_rec
BENTOML_SKIP_GCS_BOOTSTRAP=false

# GCS 인증 방식 (둘 중 하나 선택)
# 1) Base64 시크릿 주입 방식
GCS_KEY_BASE64=
# 2) 파일 기반 인증 방식 (주로 컨테이너 마운트 사용)
GOOGLE_APPLICATION_CREDENTIALS=/app/configs/gcs/gcs_key.json