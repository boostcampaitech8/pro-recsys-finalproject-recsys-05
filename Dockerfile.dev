# ==========================================
# [Development Stage] - uv 도구가 포함된 이미지 사용
# ==========================================
# 개발 중에는 패키지 추가/삭제가 빈번하므로 빌드 도구(uv)를 유지합니다.
FROM ghcr.io/astral-sh/uv:python3.11-bookworm-slim

# 작업 디렉토리 설정
WORKDIR /app

# [환경 설정]
# 1. Bytecode 컴파일 방지: 개발 중 잦은 재시작 시 불필요한 I/O 방지 및 디버거 호환성
ENV PYTHONDONTWRITEBYTECODE=1
# 2. 파이썬 버퍼링 해제: 로그가 터미널에 즉시 출력되도록 설정 (디버깅 용이)
ENV PYTHONUNBUFFERED=1
# 3. uv 링크 모드: Docker 레이어 캐싱과의 호환성을 위해 복사 모드 사용
ENV UV_LINK_MODE=copy

# [의존성 설치]
# 소스 코드는 없어도 되지만, '무엇을 설치할지' 명세서는 필요합니다.
COPY backend/pyproject.toml backend/uv.lock ./

# [핵심 변경점]
# 1. --mount=type=cache: 패키지 다운로드 속도 최적화 (프로덕션과 동일)
# 2. --frozen: uv.lock 파일 버전을 엄격하게 준수 (팀원 간 환경 일치)
# 3. (중요) --no-dev 옵션 제거: debugpy, pytest 등 개발용 패키지를 설치합니다.
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen

# [PATH 설정]
# 가상환경의 바이너리를 시스템 경로 우선순위로 등록
ENV PATH="/app/.venv/bin:$PATH"

# [소스 코드 복사 생략]
# 개발용이므로 소스 코드는 Dockerfile에서 COPY 하지 않습니다.
# docker-compose.yml의 'volumes' 기능을 통해 로컬 코드를 마운트할 것입니다.

# [포트 노출]
# 8000: API 서버 / 5678: 디버거(debugpy)
EXPOSE 8000 5678

# [실행 명령]
# 기본 실행 명령입니다. (docker-compose에서 오버라이딩 가능)
# --reload: 코드 변경 시 자동 재시작
CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]