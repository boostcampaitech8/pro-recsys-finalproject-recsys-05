# Docker Compose production env example
# Copy this file to .env on the server.

# Runtime mode
ENV=prod
DEBUG_MODE=False

# Core services
DATABASE_URL=postgresql+asyncpg://myuser:mypassword@db:5432/mydatabase
REDIS_URL=redis://redis:6379/0
ML_REC_ROOT=/app/ml_rec
BENTOML_SERVICE_URL=http://bentoml:3000

# External APIs
STEAM_API_KEY=
CLOVA_API_KEY=
CLOVA_BASE_URL=https://clovastudio.stream.ntruss.com/v1/openai/
CLOVA_RERANKER_URL=https://clovastudio.stream.ntruss.com/v1/api-tools/reranker

# Docker images
DOCKER_USERNAME=your-registry
IMAGE_TAG=latest

# GCS auth strategy: choose one and keep it consistent.
# A) File-based key (recommended): place gcs_key.json at ./configs/gcs/gcs_key.json
GOOGLE_APPLICATION_CREDENTIALS=/app/configs/gcs/gcs_key.json
# B) Base64 key injection (leave empty if using file-based key)
GCS_KEY_BASE64=
