# 운영 .env 계약 — 서버(DEPLOY_DIR)의 .env 로 복사해 값 채움. git/이미지에 절대 커밋 금지.
# deploy.sh preflight가 필수 키 존재를 검증한다 (값은 출력하지 않음).

# Runtime mode
ENV=prod
DEBUG_MODE=False

# Core services (POSTGRES_* 는 prod compose의 db 컨테이너 생성에도 쓰임 — DATABASE_URL과 일치시킬 것)
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydatabase
DATABASE_URL=postgresql+asyncpg://myuser:mypassword@db:5432/mydatabase
REDIS_URL=redis://redis:6379/0
ML_REC_ROOT=/app/ml_rec

# LLM — Gemini (OpenAI 호환). FALLBACK_MODEL은 콤마 구분 다중 지정 가능.
# 주의: gemini-2.5-flash 무료 쿼터는 하루 20회 — lite 계열을 주력으로 유지할 것.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_FALLBACK_MODEL=gemini-2.5-flash,gemini-3.5-flash
# (선택) 유료 키 — 무료 키의 모델 체인이 전부 실패(쿼터 소진)하면 이 키로 1회 더 시도.
# 미설정 시 무료 키 단일로 동작. 무료=메인 / 유료=최종 폴백.
GEMINI_FALLBACK_API_KEY=

# External APIs
STEAM_API_KEY=

# Docker images (deploy.sh/CI가 IMAGE_TAG를 인자로 덮어쓸 수 있음)
DOCKER_USERNAME=rlaqudwn
IMAGE_TAG=latest

# GCS (선택) — 데이터 파일이 서버에 사전 배치돼 있으면 불필요.
# 자동 다운로드가 필요하면 키 파일을 ./configs/gcs/gcs_key.json 에 배치.
GOOGLE_APPLICATION_CREDENTIALS=/app/configs/gcs/gcs_key.json

# BentoML (선택) — 최소 구성에선 미기동. 미설정 시 backend가 로컬 EASE로 즉시 폴백.
# BENTOML_SERVICE_URL=http://bentoml:3000
