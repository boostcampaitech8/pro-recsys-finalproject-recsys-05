# ==============================================================================
# Steam Recommendation System - Master Environment Variables (.env.example)
# ==============================================================================
# 이 파일을 '.env'로 복사한 후 실제 환경에 맞는 값을 설정하세요.
# 프로젝트 루트의 .env는 데이터 수집 파이프라인(Prefect)과 백엔드 서비스 모두에서 참조됩니다.

# 실행 환경 (local, dev, prod)
ENV=local

# ------------------------------------------------------------------------------
# 1. 외부 API 및 LLM 서비스 (필수)
# ------------------------------------------------------------------------------
# Steam Web API Key: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# Naver CLOVA Studio (LLM/RAG용)
CLOVA_API_KEY=your_clova_api_key_here

# CLOVA API 상세 경로
# RAG 추론용
CLOVA_RAG_REASONING_URL=https://clovastudio.stream.ntruss.com/v1/api-tools/rag-reasoning
# 일반 대화용
CLOVA_CHAT_BASE_URL=https://clovastudio.stream.ntruss.com/v1/openai
# Reranker용
CLOVA_RERANKER_URL=https://clovastudio.stream.ntruss.com/v1/api-tools/reranker

# ------------------------------------------------------------------------------
# 2. 인프라 설정 (Database & Redis)
# ------------------------------------------------------------------------------
# PostgreSQL (SQLAlchemy)
# - 로컬 개발 (Host): localhost:5432
# - Docker 내부: db:5432 (백엔드 코드에서 자동 전환됨)
DATABASE_URL=postgresql+asyncpg://myuser:mypassword@localhost:5432/mydatabase

# Redis
# - [Hybrid 모드]: 호스트 터미널에서 Prefect 실행 + Docker에서 서비스 실행 시 "localhost:6380" 사용
# - [Local 단독]: 호스트에 전용 Redis 설치 시 "localhost:6379" 사용
# - [Docker 내부]: 서비스 간 통신 시 "redis:6379" 사용 (백엔드 코드에서 자동 전환됨)
REDIS_URL=redis://localhost:6380

# ------------------------------------------------------------------------------
# 3. Google Cloud Storage (GCS)
# ------------------------------------------------------------------------------
# GCP 서비스 계정 키 파일 경로 (상대 경로 또는 절대 경로)
GOOGLE_APPLICATION_CREDENTIALS=./configs/gcs/gcs_key.json

# (선택) CI/CD 환경용 Base64 인코딩 키
# GCS_KEY_BASE64=

# ------------------------------------------------------------------------------
# 4. 개발 및 ML 환경 설정 (Advanced)
# ------------------------------------------------------------------------------
# Prefect 서버 연결 주소 (수동 실행 또는 스케줄링 시 필수)
# 'prefect server start' 실행 시 출력되는 'API 공식 주소'를 입력하세요 (기본값: http://127.0.0.1:4200/api)
PREFECT_API_URL="http://127.0.0.1:4200/api"

# ML/LLM 작업을 위한 전용 Python 가상환경 경로 (필요 시 설정)
# ML_PYTHON_PATH=C:\path\to\your\venv\Scripts\python.exe

# 백엔드 내 ML 모델 루트 경로 (Docker 환경 등에서 필요)
ML_REC_ROOT=/app/ml_rec

# 알림 서비스 (Slack Webhook)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ------------------------------------------------------------------------------
# 5. 프론트엔드 (참고용)
# ------------------------------------------------------------------------------
# 프론트엔드는 configs/frontend/.env 에서 별도로 관리할 수도 있습니다.
# VITE_API_URL=http://localhost:8000
